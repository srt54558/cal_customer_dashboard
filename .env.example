# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cal.com OAuth
CAL_CLIENT_ID=
CAL_CLIENT_SECRET=
SESSION_SECRET=
CAL_REDIRECT_URI=http://localhost:3000/api/auth/callback/cal
# Optional localhost demo bypass (set to 1 to force demo user/session)
LOCALHOST_AUTH_BYPASS=0

# Linear
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

# Postmark (optional, used for customer update emails)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL="Cal.com Support <support@cal.com>"
POSTMARK_MESSAGE_STREAM=outbound

# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_AUTH_ISSUER=http://localhost:3000
CONVEX_AUTH_AUDIENCE=cal-customer-portal
# Optional Convex-side auth bypass for localhost dev only
CONVEX_AUTH_BYPASS=0
CONVEX_JWT_PRIVATE_KEY=
CONVEX_JWT_PUBLIC_KEY=
CONVEX_JWT_KID=
CONVEX_INTERNAL_SECRET=
